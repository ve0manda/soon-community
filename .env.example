# انسخ هذا الملف باسم .env وعدّل القيم
PORT=3000
SESSION_SECRET=change_this_to_a_long_random_string
# الدومين الأساسي لموقعك (بدون www)، يُستخدم لاكتشاف الدومينات الفرعية
BASE_DOMAIN=example.com
# شغّل true فقط بعد ما تجهز شهادة SSL wildcard وتربط الدومينات الفرعية
ENABLE_SUBDOMAINS=false

# أسماء المستخدمين (username) اللي تبيها تصير أدمن تلقائياً، مفصولة بفاصلة
# مثال: ADMIN_USERNAMES=mahmoud,sara
ADMIN_USERNAMES=

# ---- إعدادات تسجيل الدخول عبر Discord ----
# أنشئ تطبيق من https://discord.com/developers/applications
# وحط الـ Redirect في التطبيق نفس قيمة DISCORD_REDIRECT_URI هنا بالضبط
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# ---- إعدادات تسجيل الدخول عبر Google ----
# أنشئ مشروع من https://console.cloud.google.com/apis/credentials
# وحط الـ Redirect نفس قيمة GOOGLE_REDIRECT_URI هنا بالضبط
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
