<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>لوحة الإدارة — $oon.lol</title>
  <link rel="stylesheet" href="/public/css/style.css">
  <style>
    table { width: 100%; border-collapse: collapse; font-size: 14px; }
    th, td { padding: 12px 10px; text-align: right; border-bottom: 1px solid var(--border); }
    th { color: var(--muted); font-family: 'JetBrains Mono', monospace; font-size: 12px; text-transform: uppercase; }
    .pill { display:inline-flex; align-items:center; gap:4px; font-size:11px; padding:3px 9px; border-radius:100px; font-family:'JetBrains Mono',monospace; }
    .pill-on { background:rgba(52,211,153,.15); color:#34d399; border:1px solid rgba(52,211,153,.4); }
    .pill-off { background:rgba(139,139,154,.12); color:var(--muted); border:1px solid var(--border); }
    .actions { display:flex; gap:6px; flex-wrap:wrap; }
    .actions button { padding:6px 10px; font-size:12px; }
  </style>
</head>
<body>
  <nav class="nav">
    <a href="/" class="brand"><span class="dot"></span> $oon.lol 🦇 <span style="color:var(--muted); font-size:14px;">/ الإدارة</span></a>
    <div class="nav-links">
      <a href="/dashboard" class="btn">لوحتي</a>
    </div>
  </nav>

  <div class="section">
    <% if (message) { %><div class="success-box"><%= message %></div><% } %>

    <form method="GET" action="/admin" style="margin-bottom:20px; max-width:340px;">
      <input type="text" name="q" value="<%= q %>" placeholder="ابحث باسم المستخدم أو الإيميل..."
        style="width:100%; background:var(--panel); border:1px solid var(--border); border-radius:8px; padding:10px 14px; color:var(--text);">
    </form>

    <% if (premiumRequests && premiumRequests.length) { %>
      <div class="panel" style="margin-bottom:20px;">
        <h3 style="margin-top:0;">⏳ طلبات اشتراك Premium المعلّقة (<%= premiumRequests.length %>)</h3>
        <div style="display:flex; flex-direction:column; gap:14px;">
          <% premiumRequests.forEach(r => { %>
            <div style="display:flex; gap:14px; align-items:flex-start; padding:14px; background:var(--panel-2); border-radius:10px; flex-wrap:wrap;">
              <img src="<%= r.proof_url %>" style="width:120px; height:160px; object-fit:cover; border-radius:8px; border:1px solid var(--border);">
              <div style="flex:1; min-width:200px;">
                <div style="font-weight:600;">@<%= r.username %></div>
                <div class="hint" style="margin:4px 0;">تاريخ الطلب: <%= new Date(r.created_at).toLocaleString('ar-EG') %></div>
                <% if (r.reference_note) { %><div class="hint">ملاحظة: <%= r.reference_note %></div><% } %>
              </div>
              <div class="actions">
                <form method="POST" action="/admin/premium-requests/<%= r.id %>/approve">
                  <button type="submit" class="btn" style="background:#34d399; color:#000;">✅ قبول (30 يوم)</button>
                </form>
                <form method="POST" action="/admin/premium-requests/<%= r.id %>/reject">
                  <button type="submit" class="btn" style="background:#f87171; color:#000;">❌ رفض</button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <div class="panel" style="overflow-x:auto;">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>المستخدم</th>
            <th>الإيميل</th>
            <th>Premium</th>
            <th>موثّق</th>
            <th>أدمن</th>
            <th>Discord</th>
            <th>زيارات</th>
            <th>إجراءات</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(u => { %>
            <tr>
              <td class="mono"><%= u.id %></td>
              <td><a href="/u/<%= u.username %>" target="_blank" style="color:var(--cyan);">@<%= u.username %></a></td>
              <td class="mono" style="font-size:12px;"><%= u.email %></td>
              <td><span class="pill <%= u.is_premium ? 'pill-on' : 'pill-off' %>"><%= u.is_premium ? '⭐ نعم' : 'لا' %></span></td>
              <td><span class="pill <%= u.is_verified ? 'pill-on' : 'pill-off' %>"><%= u.is_verified ? '✅ نعم' : 'لا' %></span></td>
              <td><span class="pill <%= u.is_admin ? 'pill-on' : 'pill-off' %>"><%= u.is_admin ? '🛡️ نعم' : 'لا' %></span></td>
              <td><%= u.discord_id ? '🎮 ' + u.discord_username : '—' %></td>
              <td class="mono"><%= u.views %></td>
              <td class="actions">
                <form method="POST" action="/admin/users/<%= u.id %>/toggle-premium">
                  <button type="submit" class="btn"><%= u.is_premium ? 'إلغاء Premium' : 'ترقية لـ Premium' %></button>
                </form>
                <form method="POST" action="/admin/users/<%= u.id %>/toggle-verified">
                  <button type="submit" class="btn"><%= u.is_verified ? 'إلغاء التوثيق' : 'توثيق' %></button>
                </form>
                <form method="POST" action="/admin/users/<%= u.id %>/toggle-admin">
                  <button type="submit" class="btn btn-danger"><%= u.is_admin ? 'إلغاء الأدمن' : 'ترقية لأدمن' %></button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
