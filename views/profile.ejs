<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= profile.display_name || profile.username %> — $oon.lol</title>
  <link rel="stylesheet" href="/public/css/style.css">
  <style>
    body {
      background: <%= profile.background_type === 'color' ? profile.bg_color : (profile.background_type === 'preset' ? profile.background_url : '#000') %>;
      color: <%= profile.text_color %>;
      <% if (profile.background_type === 'image') { %>
        background-image: url('<%= profile.background_url %>');
        background-size: cover;
        background-position: center;
      <% } %>
    }
  </style>
</head>
<body data-cursor="<%= profile.cursor_effect %>">
  <% if (profile.background_type === 'video' && profile.background_url) { %>
    <video autoplay muted loop playsinline style="position:fixed; inset:0; width:100%; height:100%; object-fit:cover; z-index:-1;">
      <source src="<%= profile.background_url %>">
    </video>
  <% } %>

  <canvas id="particles-canvas" data-effect="<%= profile.effect %>" data-accent="<%= profile.accent_color %>"></canvas>

  <% if (profile.audio_url) { %>
    <audio id="profile-audio" loop src="<%= profile.audio_url %>"></audio>
    <div class="audio-toggle" id="audio-toggle">▶</div>
  <% } %>

  <%
    // تحديد فئة (tier) عداد الزيارات حسب العدد
    let viewsTier = 'views-tier-0';
    if (profile.views >= 1000) viewsTier = 'views-tier-3';
    else if (profile.views >= 200) viewsTier = 'views-tier-2';
    else if (profile.views >= 50) viewsTier = 'views-tier-1';

    // تحويل card_color + card_opacity لـ rgba
    function hexToRgb(hex) {
      hex = (hex || '#0a0a0f').replace('#', '');
      if (hex.length === 3) hex = hex.split('').map(c => c + c).join('');
      const num = parseInt(hex, 16);
      return `${(num >> 16) & 255}, ${(num >> 8) & 255}, ${num & 255}`;
    }
    const cardRgb = hexToRgb(profile.card_color);
    const cardAlpha = (profile.card_opacity != null ? profile.card_opacity : 82) / 100;
  %>

  <div class="profile-page">
    <div class="profile-card <%= profile.rgb_border ? 'rgb-border' : '' %>" style="--p-accent: <%= profile.accent_color %>;">
      <div class="profile-card-inner" style="position:relative; z-index:1; background: rgba(<%= cardRgb %>, <%= cardAlpha %>);">

        <% if (profile.corner_badge) { %>
          <div class="corner-badge"><%= profile.corner_badge %></div>
        <% } %>

        <% if (avatar.type === 'video' && avatar.url) { %>
          <video class="profile-avatar" src="<%= avatar.url %>" autoplay muted loop playsinline></video>
        <% } else { %>
          <img class="profile-avatar" src="<%= avatar.url || '/public/img/default-avatar.svg' %>" alt="avatar">
        <% } %>

        <div class="profile-name">
          <%= profile.display_name || profile.username %>
        </div>

        <% if (badges.length) { %>
          <button type="button" class="badges-toggle" id="badges-toggle">
            <span class="arrow">▾</span> <%= badges.length %> شارة
          </button>
          <div class="badges-collapse" id="badges-collapse">
            <div style="display:flex; justify-content:center; flex-wrap:wrap; gap:6px; margin-bottom:10px;">
              <% badges.forEach(b => { %>
                <span class="mono" title="<%= b.label %>" style="font-size:11px; border:1px solid <%= b.color %>55; background:<%= b.color %>22; color:<%= b.color %>; padding:3px 9px; border-radius:100px;">
                  <%= b.icon %> <%= b.label %>
                </span>
              <% }) %>
            </div>
          </div>
        <% } %>

        <div class="profile-handle">@<%= profile.username %></div>
        <% if (profile.bio) { %>
          <div class="profile-bio" data-typing="<%= profile.bio %>"></div>
        <% } %>
        <div class="profile-links">
          <% links.forEach(link => {
               const isDiscord = /discord\.(gg|com)/i.test(link.url);
          %>
            <a class="profile-link <%= isDiscord ? 'is-discord' : '' %>" href="<%= link.url %>" target="_blank" rel="noopener">
              <% if (isDiscord) { %>🎮 <% } %><%= link.label %>
            </a>
          <% }) %>
        </div>
        <div class="profile-views <%= viewsTier %>">👁 <%= profile.views %> زيارة</div>
      </div>
    </div>
  </div>

  <script src="/public/js/profile-effects.js"></script>
  <script>
    const badgesToggle = document.getElementById('badges-toggle');
    const badgesCollapse = document.getElementById('badges-collapse');
    if (badgesToggle && badgesCollapse) {
      badgesToggle.addEventListener('click', () => {
        badgesToggle.classList.toggle('open');
        badgesCollapse.classList.toggle('open');
      });
    }
  </script>
</body>
</html>
